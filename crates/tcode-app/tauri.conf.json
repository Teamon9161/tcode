{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tcode",
  "version": "0.1.22",
  "identifier": "dev.tcode.desktop",
  "build": {
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "tcode",
        "width": 1280,
        "height": 860,
        "minWidth": 760,
        "minHeight": 520,
        "backgroundColor": "#ffffff"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png"
    ]
  }
}
